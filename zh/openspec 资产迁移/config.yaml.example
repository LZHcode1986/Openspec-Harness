schema: project-schema

context: |
  Project: <项目名称>
  Domain: <业务领域或产品领域>
  Product boundary: <产品边界，说明系统是做什么、不做什么>
  MVP scope: <MVP 范围，尽量写成单一闭环>
  Primary use cases: <主要使用场景列表>
  Explicit non-goals for MVP: <MVP 明确不做的事项>
  Tech stack: <技术栈，按项目实际填写>
  Architecture: <架构约束或分层说明>
  Core roles: <核心角色或系统参与方>
  Shared principles: <共享原则列表>
  State model: <状态机或阶段模型，写出权威状态名>
  Canonical objects: <核心对象或权威数据结构列表>
  API principles: <API / contract 原则>
  Testing posture: <测试策略，如 TDD-first、契约测试、E2E 等>
  Documentation language: <文档语言要求>
  Authority order: <权威来源顺序，说明哪个文档优先级最高>

rules:
  proposal:
    - <提案阶段的硬性要求 1>
    - <提案阶段的硬性要求 2>
    - <提案阶段的硬性要求 3>
  specs:
    - <规范阶段的硬性要求 1>
    - <规范阶段的硬性要求 2>
  design:
    - <设计阶段的硬性要求 1>
    - <设计阶段的硬性要求 2>
  tasks:
    - <任务阶段的硬性要求 1>
    - <任务阶段的硬性要求 2>
  implementation:
    - <实施阶段的硬性要求 1>
    - <实施阶段的硬性要求 2>

traceability:
  <reference-change-or-arch-slice>:
    artifact: <artifact-name>
    description: <说明>
    reference: <引用路径或链接>
    enabled: true
  <another-reference>:
    artifact: <artifact-name>
    description: <说明>
    applies_to: <proposal|design|specs|tasks|implementation>

